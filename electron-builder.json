{
  "appId": "br.ceia.frota",
  "productName": "CEIA Frota",
  "directories": {
    "output": "release"
  },
  "files": [
    {
      "from": "dist",
      "to": "dist",
      "filter": [
        "**/*"
      ]
    },
    {
      "from": "electron",
      "to": "electron",
      "filter": [
        "**/*"
      ]
    },
    "package.json"
  ],
  "linux": {
    "target": [
      {
        "target": "deb",
        "arch": [
          "x64"
        ]
      }
    ],
    "icon": "electron/icons/png/icon.png",
    "category": "public.app-category.business",
    "maintainer": "CEIA <contato@ceia.ia.br>",
    "vendor": "CEIA"
  },
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      }
    ],
    "icon": "electron/icons/win/icon.ico"
  },
  "mac": {
    "target": [
      {
        "target": "dmg",
        "arch": [
          "x64"
        ]
      }
    ],
    "icon": "electron/icons/mac/icon.icns",
    "category": "public.app-category.business",
    "hardenedRuntime": false,
    "gatekeeperAssess": false
  },
  "nsis": {
    "installerIcon": "electron/icons/win/icon.ico",
    "uninstallerIcon": "electron/icons/win/icon.ico"
  },
  "publish": {
    "provider": "github",
    "owner": "franksushiman",
    "repo": "frota.ceia",
    "releaseType": "release"
  },
  "npmRebuild": false,
  "asarUnpack": ["dist/**/*", "node_modules/**/*"]
}