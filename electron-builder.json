{
  "appId": "br.ceia.frota",
  "productName": "CEIA Frota",
  "directories": {
    "output": "release"
  },
  "files": ["dist/**/*", "electron/**/*", "node_modules/**/*", "package.json"],
  "linux": {
    "target": [{ "target": "deb", "arch": ["x64"] }],
    "icon": "electron/icons/png/icon.png",
    "category": "public.app-category.business",
    "maintainer": "CEIA <contato@ceia.ia.br>",
    "vendor": "CEIA"
  },
  "win": {
    "target": [{ "target": "nsis", "arch": ["x64"] }],
    "icon": "electron/icons/win/icon.ico"
  },
  "mac": {
    "target": [{ "target": "dmg", "arch": ["x64", "arm64"] }],
    "icon": "electron/icons/mac/icon.icns",
    "category": "public.app-category.business",
    "hardenedRuntime": true,
    "gatekeeperAssess": false
  },
  "nsis": {
    "installerIcon": "electron/icons/win/icon.ico",
    "uninstallerIcon": "electron/icons/win/icon.ico"
  },
  "publish": {
    "provider": "github",
    "owner": "franksushiman",
    "repo": "frota.ceia"
  }
}
